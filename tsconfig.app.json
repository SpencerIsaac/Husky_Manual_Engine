{
  "compilerOptions": {
    // TypeScript caches build metadata here to speed up future checks.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    // The app targets modern JavaScript runtimes.
    "target": "ES2023",
    "useDefineForClassFields": true,
    // Include browser APIs such as `document`, `fetch`, and iterable DOM helpers.
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    // Vite injects helper types such as `import.meta.env`.
    "types": ["vite/client"],
    // Skip deep type-checking inside installed packages to keep development fast.
    "skipLibCheck": true,

    /* Bundler mode */
    // Let Vite's bundler-style module rules drive import resolution.
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    // Preserve import/export syntax as written so the bundler can handle it.
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    // TypeScript checks the code but does not write compiled files itself.
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    // These settings make the project stricter and help catch mistakes earlier.
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  // The browser app source lives in `src`.
  "include": ["src"]
}
