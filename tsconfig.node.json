{
  "compilerOptions": {
    // Separate cache file for Node-side tooling such as Vite config.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2023",
    // Only Node runtime libraries are needed here, not browser APIs.
    "lib": ["ES2023"],
    "module": "ESNext",
    // Expose Node-specific globals and types.
    "types": ["node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  // Only the Vite config is checked with this Node-oriented setup.
  "include": ["vite.config.ts"]
}
